# ============================================================
# Vexaro KYC Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# Server
PORT=5000

# PostgreSQL Connection
# Local example:  postgresql://postgres:yourpassword@localhost:5432/vexaro_kyc
# Neon example:   postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/vexaro_kyc?sslmode=require
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/vexaro_kyc

# JWT Secret (change this to a long random string in production)
JWT_SECRET=vexaro_super_secret_jwt_key_change_me_in_production

# JWT Expiry
JWT_EXPIRES_IN=7d

# File Upload Limits
MAX_FILE_SIZE_MB=5

# WhatsApp Business Cloud API
# Leave blank to skip automatic WhatsApp sending.
WHATSAPP_PHONE_NUMBER_ID=your_meta_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_API_VERSION=v20.0
WHATSAPP_DEFAULT_COUNTRY_CODE=91

WHATSAPP_KYC_APPROVED_TEMPLATE_NAME=kyc_approved
WHATSAPP_KYC_APPROVED_TEMPLATE_LANGUAGE=en_US
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token